# Copy this file to .env and adjust values as needed.
# Docker Compose will automatically load .env in the project root.

# Web service
WEB_PORT=8000
DEBUG=false
ALLOWED_HOSTS=127.0.0.1,localhost
SECRET_KEY=django-insecure-dev-only-change-me

# Database (used by both db and web services)
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=gutendex
DATABASE_USER=gutendex
DATABASE_PASSWORD=gutendex

# Optional operational flags
RUN_UPDATECATALOG_ON_STARTUP=false
DB_WAIT_TIMEOUT=120

# Optional email/admin settings (can stay empty)
ADMIN_EMAILS=
ADMIN_NAMES=
MANAGER_EMAILS=
MANAGER_NAMES=
EMAIL_HOST=
EMAIL_HOST_ADDRESS=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
